<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.danieldpereira.usersystem.controller.DashboardController">

    <top>
        <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <Label fx:id="lblBemVindo" text="Bem-vindo, Usuário">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
            </Label>
            <Button onAction="#handleLogout" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-cursor: hand;" text="Sair" />
        </HBox>
    </top>

    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Gestão de Usuários">
                    <VBox spacing="15.0">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <Label text="Gerenciamento de Usuários">
                                <font><Font size="20.0" /></font>
                            </Label>

                            <TextField fx:id="txtBuscaUsuario" prefWidth="250.0" promptText="🔍 Buscar nome ou email..." style="-fx-background-radius: 15;" />

                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleNovoUsuario" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-cursor: hand;" text="+ Novo Usuário" />
                            <Button fx:id="btnEditar" disable="true" onAction="#handleEditarUsuario" style="-fx-cursor: hand;" text="Editar" />
                            <Button fx:id="btnExcluir" disable="true" onAction="#handleExcluirUsuario" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-cursor: hand;" text="Excluir" />
                        </HBox>

                        <TableView fx:id="tabelaUsuarios" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colUsuario" prefWidth="150.0" text="Usuário" />
                                <TableColumn fx:id="colEmail" prefWidth="200.0" text="Email" />
                                <TableColumn fx:id="colNivel" prefWidth="100.0" text="Nível" />
                                <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER" spacing="20.0">
                            <Button fx:id="btnPrevUsuario" onAction="#handlePrevUsuario" style="-fx-cursor: hand;" text="&lt; Anterior" />
                            <Label fx:id="lblPaginaUsuario" style="-fx-font-weight: bold;" text="Página 1 de 1" />
                            <Button fx:id="btnNextUsuario" onAction="#handleNextUsuario" style="-fx-cursor: hand;" text="Próxima &gt;" />
                        </HBox>
                    </VBox>
                </Tab>

                <Tab fx:id="tabAuditoria" text="Auditoria de Sistema">
                    <VBox spacing="15.0">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <Label text="Logs de Atividade">
                                <font><Font size="20.0" /></font>
                            </Label>

                            <TextField fx:id="txtBuscaLog" prefWidth="300.0" promptText="🔍 Buscar por ação ou detalhes..." style="-fx-background-radius: 15;" />
                        </HBox>

                        <TableView fx:id="tabelaLogs" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colLogId" prefWidth="60.0" text="ID Log" />
                                <TableColumn fx:id="colLogData" prefWidth="150.0" text="Data/Hora" />
                                <TableColumn fx:id="colLogUsuarioId" prefWidth="80.0" text="ID Usuário" />
                                <TableColumn fx:id="colLogAcao" prefWidth="150.0" text="Ação" />
                                <TableColumn fx:id="colLogDetalhes" prefWidth="300.0" text="Detalhes" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER" spacing="20.0">
                            <Button fx:id="btnPrevLog" onAction="#handlePrevLog" style="-fx-cursor: hand;" text="&lt; Anterior" />
                            <Label fx:id="lblPaginaLog" style="-fx-font-weight: bold;" text="Página 1 de 1" />
                            <Button fx:id="btnNextLog" onAction="#handleNextLog" style="-fx-cursor: hand;" text="Próxima &gt;" />
                        </HBox>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </center>

</BorderPane>